<manifest>
    <!-- Remotes -->
    <remote name="ax" fetch="https://github.com/AxionAOSP-devices" />
    <remote name="dd" fetch="https://github.com/DarkDolphin1" />
    <remote name="pong-dev" fetch="https://github.com/Pong-Development" />
    <remote name="org-github" fetch="https://github.com/Nothing-2A" />
    <remote name="org-gitlab" fetch="https://gitlab.com/nothing-2a" />

    <!-- Device -->
    <project path="device/nothing/Aerodactyl" name="device_nothing_Aerodactyl"
