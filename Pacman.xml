    <project path="vendor/nothing/Pacman"
        name="proprietary_vendor_nothing_Pacman"
        remote="org-gitlab" revision="lineage-23.2" />

    <!-- Glyph -->
    <project path="packages/apps/ParanoidGlyph"
        name="android_packages_apps_ParanoidGlyph"
        remote="dd" revision="lineage-23.1" />

    <project path="packages/apps/GlyphAdapter"
