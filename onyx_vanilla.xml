<?xml version="1.0" encoding="UTF-8"?>
<manifest>
    <remote name="ax" fetch="https://github.com/AxionAOSP-devices" />
    <remote name="za" fetch="https://github.com/Zarathos30/" />
    
    <!-- Framework/base fork (N-CPU cluster support) -->
    <remove-project name="android_frameworks_base" />
    <project path="frameworks/base" name="android_frameworks_base" remote="za" revision="axion-2.7" />

    <!-- AxionParts fork (N-CPU cluster UI) -->
    <remove-project name="android_packages_apps_AxionParts" />
    <project path="packages/apps/AxionParts" name="android_packages_apps_AxionParts" remote="za" revision="axion-2.7" />

    <!-- Device -->
    <project path="device/xiaomi/onyx" name="android_device_xiaomi_onyx" remote="ax" revision="axion-vanilla" />
    
    <!-- Kernel -->
    <project path="device/xiaomi/onyx-kernel" name="android_kernel_xiaomi_onyx" remote="ax" revision="lineage-23.2" />

    <!-- Hardware -->
    <project path="hardware/xiaomi" name="android_hardware_xiaomi" remote="ax" revision="lineage-23.2" />
    
    <!-- Vendor -->
    <project path="vendor/xiaomi/onyx" name="android_vendor_xiaomi_onyx" remote="ax" revision="axion" />
    
    <!-- MiuiCamera -->
    <project path="device/xiaomi/onyx-miuicamera" name="android_device_xiaomi_onyx-miuicamera" remote="ax" revision="lineage-23.2" />
    <project path="vendor/xiaomi/onyx-miuicamera" name="proprietary_vendor_xiaomi_onyx-miuicamera" remote="ax" revision="sixteen-qpr2" />

    <!-- Prop name length fixes -->
    <remove-project path="system/core" />
    <project path="system/core" name="android_system_core" remote="za" revision="lineage-23.2" />

    <remove-project path="axion_sdk" />
    <project path="axion_sdk" name="android_axion_sdk" remote="za" revision="lineage-23.2" />

    <remove-project path="packages/apps/VendorSupport" />
    <project path="packages/apps/VendorSupport" name="android_packages_apps_VendorSupport" remote="za" revision="lineage-23.2" />

    <remove-project path="vendor/lineage" />
    <project path="vendor/lineage" name="android_vendor_lineage" remote="za" revision="lineage-23.2" />
</manifest>
